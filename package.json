{
  "name": "sinal",
  "description": "Um aplicativo de chat e mensagens em tempo real para conexoes rapidas e seguras.",
  "author": "Julio Cesar O. Bueno <https://github.com/hasbuen>",
  "version": "0.2.3",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "electron:icon": "node tools/generate-electron-icon.cjs",
    "desktop:dev": "concurrently -k \"npm:dev\" \"wait-on http://localhost:3000 && electron .\"",
    "desktop:build": "npm run electron:icon && electron-builder --win nsis",
    "desktop:release": "npm run electron:icon && electron-builder --win nsis --publish always",
    "backend:dev": "npm --prefix backend run dev",
    "backend:build": "npm --prefix backend run build",
    "backend:typecheck": "npm --prefix backend run typecheck",
    "backend:prisma:generate": "npm --prefix backend run prisma:generate",
    "backend:prisma:push": "npm --prefix backend run prisma:push",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "cd android && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@emoji-mart/data": "^1.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "driver.js": "^1.4.0",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.23.12",
    "graphql-ws": "^6.0.6",
    "lucide-react": "^0.543.0",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "react-zoom-pan-pinch": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^2.1.8",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.hasbuen.sinal.desktop",
    "productName": "Sinal",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release/electron",
      "buildResources": "electron/build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "hasbuen",
        "repo": "Sinal"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
